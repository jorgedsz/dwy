generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  password              String
  name                  String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assignments           ClientAssignment[]
  waProjects            WaProject[]
  calendarIntegrations  CalendarIntegration[]
}

model Client {
  id                  Int                @id @default(autoincrement())
  name                String
  email               String?
  phone               String?
  company             String?
  notes               String?
  portalToken         String?            @unique
  startDate           DateTime?
  contractedSessions  Int?
  twilioAccountSid    String?            @db.Text
  twilioAuthToken     String?            @db.Text
  assignments         ClientAssignment[]
  sessions            Session[]
  waProjects          WaProject[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ClientAssignment {
  id       Int    @id @default(autoincrement())
  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String // "cs" or "ops"

  @@unique([clientId, userId, role])
}

model Session {
  id            Int            @id @default(autoincrement())
  clientId      Int
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type          String
  title         String
  date          DateTime
  recordingUrl  String?
  transcription String?        @db.Text
  aiSummary     String?        @db.Text
  pendingItems  String?        @db.Text
  pendingTasks  PendingTask[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([clientId, date])
}

model PendingTask {
  id          Int       @id @default(autoincrement())
  sessionId   Int
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([sessionId])
}

model WaProject {
  id                Int              @id @default(autoincrement())
  nombre            String
  cliente           String?
  estado            String           @default("activo")
  prioridad         String           @default("media")
  responsable       String?
  progreso          Int              @default(0)
  whatsappChatId    String?
  totalMensajes     Int              @default(0)
  alertasCount      Int              @default(0)
  ultimoMensaje     String?
  ultimaActividad   DateTime?
  colorEmoji        String?
  projectType       String?
  descripcionEmpresa String?
  objetivoProyecto  String?
  userId            Int
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId          Int?
  client            Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  messages          WaProjectMessage[]
  alerts            WaProjectAlert[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  @@unique([userId, whatsappChatId])
  @@index([userId, estado])
}

model WaProjectMessage {
  id              Int              @id @default(autoincrement())
  projectId       Int
  project         WaProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fuente          String           @default("whatsapp")
  sender          String
  contenido       String
  timestamp       DateTime
  esDelCliente    Boolean          @default(true)
  metadata        String?
  alerts          WaProjectAlert[]
  createdAt       DateTime         @default(now())
  @@index([projectId, timestamp])
}

model WaProjectAlert {
  id              Int              @id @default(autoincrement())
  projectId       Int
  project         WaProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messageId       Int?
  message         WaProjectMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  tipo            String
  nivel           String
  descripcion     String
  resuelta        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  @@index([projectId, resuelta])
}

model WaBotConfig {
  id              Int              @id @default(autoincrement())
  userId          Int              @unique
  teamKeywords    String           @default("[]")
  blockedGroups   String           @default("[]")
  alertRules      String?
  enabled         Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Chatbot {
  id            Int      @id @default(autoincrement())
  userId        Int
  name          String
  systemPrompt  String?  @db.Text
  tools         String   @default("[]") @db.Text
  config        String   @default("{}") @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model CalendarIntegration {
  id                 Int       @id @default(autoincrement())
  userId             Int
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String    @default("google")
  accessToken        String    @db.Text
  refreshToken       String    @db.Text
  externalAccountId  String
  calendarId         String    @default("primary")
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, provider, externalAccountId])
  @@index([userId])
}
